function Library:CreateSliderNotches(Track, Min, Max, Rounding)
    local step = 1;
    if Rounding and Rounding > 0 then
        step = 10 ^ (-Rounding);
    end;

    local divisions = math.floor((Max - Min) / step);
    if divisions < 2 then
        return;
    end;

    if divisions > 20 then
        divisions = 20;
    end;

    for Index = 1, divisions - 1 do
        local Notch = Library:Create('Frame', {
            AnchorPoint = Vector2.new(0.5, 0.5);
            BackgroundColor3 = Library.OutlineColor;
            BorderSizePixel = 0;
            Position = UDim2.new(Index / divisions, 0, 0.5, 0);
            Size = UDim2.new(0, 1, 0, 5);
            ZIndex = 8;
            Parent = Track;
        });

        Library:AddToRegistry(Notch, {
            BackgroundColor3 = 'OutlineColor';
        });
    end;
end;

function Library:AttachWindowResizeGrip(Outer, Config)
    Config = Config or {};

    local MinSize = Config.ResizeMin or Vector2.new(420, 320);
    local MaxSize = Config.ResizeMax or Vector2.new(1100, 1400);
    local GripSize = Config.ResizeGripSize or 18;
    local CircleSize = GripSize * 2;

    local GripClip = Library:Create('TextButton', {
        AnchorPoint = Vector2.new(1, 1);
        AutoButtonColor = false;
        BackgroundTransparency = 1;
        BorderSizePixel = 0;
        Position = UDim2.new(1, 0, 1, 0);
        Size = UDim2.new(0, GripSize, 0, GripSize);
        ClipsDescendants = true;
        Text = '';
        ZIndex = 50;
        Parent = Outer;
    });

    local GripFill = Library:Create('Frame', {
        AnchorPoint = Vector2.new(0.5, 0.5);
        BackgroundColor3 = Library.AccentColor;
        BorderSizePixel = 0;
        Position = UDim2.new(1, 0, 1, 0);
        Size = UDim2.new(0, CircleSize, 0, CircleSize);
        ZIndex = 51;
        Parent = GripClip;
    });

    Library:Create('UICorner', {
        CornerRadius = UDim.new(1, 0);
        Parent = GripFill;
    });

    Library:AddToRegistry(GripFill, {
        BackgroundColor3 = 'AccentColor';
    });

    local Resizing = false;
    local StartMouse;
    local StartSize;

    local function SetGripColor(Color)
        GripFill.BackgroundColor3 = Color;
    end;

    GripClip.MouseEnter:Connect(function()
        if not Resizing then
            SetGripColor(Library.AccentHover or Library:GetLighterColor(Library.AccentColor, 0.42));
        end;
    end);

    GripClip.MouseLeave:Connect(function()
        if not Resizing then
            SetGripColor(Library.AccentColor);
        end;
    end);

    GripClip.InputBegan:Connect(function(Input)
        if Input.UserInputType ~= Enum.UserInputType.MouseButton1 or Library:MouseIsOverOpenedFrame() then
            return;
        end;

        Resizing = true;
        Library._ResizingWindow = true;
        StartMouse = Vector2.new(Mouse.X, Mouse.Y);
        StartSize = Outer.Size;
        SetGripColor(Color3.new(1, 1, 1));
    end);

  local function StopResize()
        if not Resizing then
            return;
        end;

        Resizing = false;
        Library._ResizingWindow = false;
        SetGripColor(Library.AccentColor);
    end;

    Library:GiveSignal(InputService.InputEnded:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 then
            StopResize();
        end;
    end));

    Library:GiveSignal(InputService.InputChanged:Connect(function(Input)
        if not Resizing or Input.UserInputType ~= Enum.UserInputType.MouseMovement then
            return;
        end;

        local Delta = Vector2.new(Mouse.X, Mouse.Y) - StartMouse;
        local NewWidth = math.clamp(StartSize.X.Offset + Delta.X, MinSize.X, MaxSize.X);
        local NewHeight = math.clamp(StartSize.Y.Offset + Delta.Y, MinSize.Y, MaxSize.Y);

        Outer.Size = UDim2.fromOffset(NewWidth, NewHeight);
        Library:UpdateWindowSizeLabels();
    end));
end;

