                if Library:IsMouseOverGui(PickerFrameOuter)
                    or Library:IsMouseOverGui(DisplayFrame)
                    or Library:IsMouseOverGui(Library.WindowOuter) then
                    return;
                end;

                ColorPicker:Hide();
            end;
        end))

        ColorPicker:Display();
        ColorPicker.DisplayFrame = DisplayFrame

        if ParentObj.Addons then
            table.insert(ParentObj.Addons, ColorPicker);
        end;

        Options[Idx] = ColorPicker;

        return self;
    end;

    function Funcs:AddKeyPicker(Idx, Info)
