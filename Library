function Library:ApplyKeybindRowStripes()
    if not Library.KeybindContainer then
        return;
    end;

    local Rows = {};

    for _, Child in next, Library.KeybindContainer:GetChildren() do
        if Child:IsA('Frame') and Child.Name == 'KeybindRow' and Child.Visible then
            table.insert(Rows, Child);
        end;
    end;

    table.sort(Rows, function(A, B)
        return A.LayoutOrder < B.LayoutOrder;
    end);

    for Index, Row in ipairs(Rows) do
        local Background = Row:FindFirstChild('RowBackground');
        if Background then
            Background.BackgroundColor3 = Index % 2 == 0 and Library.KeybindAltColor or Library.MainColor;
        end;
    end;
end;

function Library:RefreshKeybindList()
    if not Library.KeybindListVisible then
        Library.KeybindFrame.Visible = false;
        return;
    end;

    Library:ApplyKeybindRowStripes();

    local YSize = 0;
    local XSize = 0;
    local HasRows = false;

    for _, Row in next, Library.KeybindContainer:GetChildren() do
        if Row:IsA('Frame') and Row.Name == 'KeybindRow' and Row.Visible then
            HasRows = true;
            YSize = YSize + Row.Size.Y.Offset;

            local NameLabel = Row:FindFirstChild('RowNameLabel');
            local KeyLabel = Row:FindFirstChild('RowKeyLabel');

            if NameLabel and NameLabel.TextBounds.X > XSize then
                XSize = NameLabel.TextBounds.X;
            end;

            if KeyLabel and KeyLabel.TextBounds.X > XSize then
                XSize = KeyLabel.TextBounds.X;
            end;
        end;
    end;

    Library.KeybindFrame.Visible = HasRows;

    local Pad = Library.ColorPickerPad or 8;
    local HeaderH = 16 + 4 + 1 + 5;

    Library.KeybindFrame.Size = UDim2.new(
        0,
        math.max(XSize + Pad * 2 + 40, 170),
        0,
        YSize + HeaderH + Pad * 2 + 2
    );
end;

