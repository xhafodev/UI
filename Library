end;

function Library:MakeWindowDraggable(Instance, Cutoff)
    Instance.Active = true;

    Instance.InputBegan:Connect(function(Input)
        if Input.UserInputType ~= Enum.UserInputType.MouseButton1 then
            return;
        end;

        local ObjPos = Vector2.new(
            Mouse.X - Instance.AbsolutePosition.X,
            Mouse.Y - Instance.AbsolutePosition.Y
        );

        if ObjPos.Y > (Cutoff or 40) then
            return;
        end;

        local PreviewSize = Instance.AbsoluteSize;
        local StartTopLeft = Instance.AbsolutePosition;
        local Preview = Library:CreateWindowDragPreview(StartTopLeft, PreviewSize);

        while InputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
            local TopLeft = Vector2.new(Mouse.X - ObjPos.X, Mouse.Y - ObjPos.Y);

            Library:UpdateWindowDragPreview(Preview, TopLeft);
            RenderStepped:Wait();
        end;

        local TopLeft = Vector2.new(Mouse.X - ObjPos.X, Mouse.Y - ObjPos.Y);

        Instance.Position = UDim2.new(
            0,
            TopLeft.X + (Instance.Size.X.Offset * Instance.AnchorPoint.X),
            0,
            TopLeft.Y + (Instance.Size.Y.Offset * Instance.AnchorPoint.Y)
        );

        Library:DestroyWindowDragPreview(Preview);
    end);
end;

