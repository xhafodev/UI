function Library:Tween(Instance, Goal, Duration, Style, Direction)
    local Tween = TweenService:Create(
        Instance,
        TweenInfo.new(Duration or 0.22, Style or Enum.EasingStyle.Quad, Direction or Enum.EasingDirection.Out),
        Goal
    );

    Tween:Play();
    return Tween;
end;

function Library:ApplyBorderInset(Parent)
    if Parent:FindFirstChildOfClass('UIPadding') then
        return;
    end;

    local Inset = Library.BorderInset or 1;

    Library:Create('UIPadding', {
        PaddingLeft = UDim.new(0, Inset);
        PaddingRight = UDim.new(0, Inset);
        PaddingTop = UDim.new(0, Inset);
        PaddingBottom = UDim.new(0, Inset);
        Parent = Parent;
    });
end;

function Library:IsSizedElement(Instance)
    return Instance:IsA('GuiObject');
end;

function Library:DockColorPickerFrame(Frame)
    if not Frame then
        return;
    end;

    local WindowOuter = Library.WindowOuter;
    local Gap = Library.ColorPickerGap or 8;
    local Size = 350;

    if WindowOuter and WindowOuter.Parent then
        local WindowHeight = WindowOuter.AbsoluteSize.Y;

        if WindowHeight > 0 then
            Size = math.max(math.floor(WindowHeight / 2), 180);
        end;

        local WindowPos = WindowOuter.AbsolutePosition;
        local WindowSize = WindowOuter.AbsoluteSize;

        Frame.Position = UDim2.fromOffset(
            WindowPos.X + WindowSize.X + Gap,
            WindowPos.Y
        );
    end;

    Frame.Size = UDim2.fromOffset(Size, Size);
    Frame.AnchorPoint = Vector2.new(0, 0);

    local Layout = Library.ColorPickerLayouts[Frame];

    if Layout then
        Library:LayoutColorPickerInner(Frame:FindFirstChildWhichIsA('Frame'), Layout);
    end;
end;

function Library:PositionFloatingList(ListFrame, AnchorFrame, ListHeight, ListWidth)
    if not ListFrame or not AnchorFrame then
        return;
    end;

    local Position = AnchorFrame.AbsolutePosition;
    local Size = AnchorFrame.AbsoluteSize;
    local Height = ListHeight or ListFrame.Size.Y.Offset;

    ListFrame.Position = UDim2.fromOffset(Position.X, Position.Y + Size.Y);
    ListFrame.Size = UDim2.fromOffset(ListWidth or math.max(Size.X, 1), Height);
end;

function Library:GetModeSelectSize(ModeCount)
    local Pad = Library.ColorPickerPad or 8;
    local Gap = Library.ColorPickerSectionGap or 5;
    local RowH = 18;
    local InnerH = ModeCount * RowH + math.max(0, ModeCount - 1) * Gap;

    return 96, Pad * 2 + InnerH + 2;
end;

function Library:ShowModeSelectPicker(ModeSelectOuter, PickOuter, ModeCount)
    local Width, Height = Library:GetModeSelectSize(ModeCount);

    Library:PositionFloatingList(ModeSelectOuter, PickOuter, Height, Width);
    ModeSelectOuter.Visible = true;
end;

function Library:LayoutColorPickerInner(PickerFrameInner, Layout)
    if not PickerFrameInner or not Layout then
        return;
    end;

    local Height = PickerFrameInner.AbsoluteSize.Y;

    if Height <= 0 then
        Height = Layout.LastHeight or 350;
    else
        Layout.LastHeight = Height;
    end;

    local Pad = Library.ColorPickerPad or 8;
    local Gap = Library.ColorPickerSectionGap or 5;
    local TitleH = 16;
    local LineY = Pad + TitleH + 4;
    local LineH = 1;
    local BodyY = LineY + LineH + Gap;
    local HueH = 12;
    local InputH = 20;
    local BtnH = 22;
    local HalfGap = math.floor(Gap / 2);

    if Layout.TitleLabel then
        Layout.TitleLabel.Position = UDim2.fromOffset(Pad, Pad);
        Layout.TitleLabel.Size = UDim2.new(0.5, -Pad, 0, TitleH);
    end;

    if Layout.FlagLabel then
        Layout.FlagLabel.Position = UDim2.new(0.5, 0, 0, Pad);
        Layout.FlagLabel.Size = UDim2.new(0.5, -Pad, 0, TitleH);
    end;

    if Layout.HeaderLine then
        Layout.HeaderLine.Position = UDim2.new(0, Pad, 0, LineY);
        Layout.HeaderLine.Size = UDim2.new(1, -Pad * 2, 0, LineH);
    end;

    local BottomH = InputH + Gap + BtnH + Gap + BtnH + Pad;
    local MapH = math.max(Height - BodyY - HueH - Gap - BottomH, 60);

    Layout.SatVibMapOuter.Position = UDim2.new(0, Pad, 0, BodyY);
    Layout.SatVibMapOuter.Size = UDim2.new(1, -Pad * 2, 0, MapH);

    Layout.HueSelectorOuter.Position = UDim2.new(0, Pad, 0, BodyY + MapH + Gap);
    Layout.HueSelectorOuter.Size = UDim2.new(1, -Pad * 2, 0, HueH);

    local InputY = BodyY + MapH + Gap + HueH + Gap;

    Layout.RBoxOuter.Position = UDim2.new(0, Pad, 0, InputY);
    Layout.RBoxOuter.Size = UDim2.new(0.25, -5, 0, InputH);
    Layout.GBoxOuter.Position = UDim2.new(0.25, 1, 0, InputY);
    Layout.GBoxOuter.Size = UDim2.new(0.25, -5, 0, InputH);
    Layout.BBoxOuter.Position = UDim2.new(0.5, -2, 0, InputY);
    Layout.BBoxOuter.Size = UDim2.new(0.25, -5, 0, InputH);
    Layout.HexBoxOuter.Position = UDim2.new(0.75, -3, 0, InputY);
    Layout.HexBoxOuter.Size = UDim2.new(0.25, -1, 0, InputH);

    local BtnY = InputY + InputH + Gap;

    Layout.CopyBtnOuter.Position = UDim2.new(0, Pad, 0, BtnY);
    Layout.CopyBtnOuter.Size = UDim2.new(0.5, -HalfGap, 0, BtnH);
    Layout.PasteBtnOuter.Position = UDim2.new(0.5, HalfGap, 0, BtnY);
    Layout.PasteBtnOuter.Size = UDim2.new(0.5, -HalfGap, 0, BtnH);

    Layout.ConfirmBtnOuter.Position = UDim2.new(0, Pad, 0, BtnY + BtnH + Gap);
    Layout.ConfirmBtnOuter.Size = UDim2.new(1, -Pad * 2, 0, BtnH);
end;

function Library:EnsureColorPickerDock()
    local Outer = Library.WindowOuter;

    if not Outer or Library.ColorPickerDockConnection then
        return;
    end;

    local function UpdateDock()
        if Library.ActiveColorPickerFrame and Library.ActiveColorPickerFrame.Visible then
            Library:DockColorPickerFrame(Library.ActiveColorPickerFrame);
        end;
    end;

    Library.ColorPickerDockConnection = true;
    Library:GiveSignal(Outer:GetPropertyChangedSignal('Position'):Connect(UpdateDock));
    Library:GiveSignal(Outer:GetPropertyChangedSignal('Size'):Connect(UpdateDock));
end;

function Library:CloseAllColorPickers()
    for _, Option in next, Options do
        if type(Option) == 'table' and Option.Type == 'ColorPicker' and Option.Hide then
            Option:Hide();
        end;
    end;

    Library.ActiveColorPickerFrame = nil;
end;

function Library:IsMouseOverGui(GuiObject)
    if not GuiObject or not GuiObject.Visible then
        return false;
    end;

    local Position = GuiObject.AbsolutePosition;
    local Size = GuiObject.AbsoluteSize;

    return Mouse.X >= Position.X and Mouse.X <= Position.X + Size.X
        and Mouse.Y >= Position.Y and Mouse.Y <= Position.Y + Size.Y;
end;

function Library:CreateAccentLine(Parent, Properties)
    Properties = Properties or {};

    local Line = Library:Create('Frame', {
        BackgroundColor3 = Color3.new(1, 1, 1);
        BorderSizePixel = 0;
        Size = Properties.Size or UDim2.new(1, 0, 0, 1);
        Position = Properties.Position or UDim2.new(0, 0, 0, 0);
        ZIndex = Properties.ZIndex or 5;
        Parent = Parent;
    });

    local Gradient = Library:Create('UIGradient', {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Library.MainColor);
            ColorSequenceKeypoint.new(0.4, Library.AccentColor);
            ColorSequenceKeypoint.new(0.6, Library.AccentColor);
            ColorSequenceKeypoint.new(1, Library.MainColor);
        });
        Offset = Vector2.new(-1, 0);
        Parent = Line;
    });

    table.insert(Library.AccentLines, {
        Frame = Line;
        Gradient = Gradient;
    });

    Library:ApplyAccentLineGradient(
        Gradient,
        Library:NormalizeAccentLineStyle(Library.AccentLineStyle),
        Library.AccentLinePhase or 0
    );

    if not Library.AccentLineConnection then
        Library.AccentLineConnection = RenderStepped:Connect(function(Delta)
            Library:UpdateAccentLines(Delta);
        end);

        Library:GiveSignal(Library.AccentLineConnection);
    end;

    return Line;
end;

function Library:NormalizeAccentLineStyle(Style)
    if type(Style) ~= 'string' then
        return 'static';
    end;

    local Normalized = Style:lower();

    for _, Name in next, Library.AccentLineStyles do
        if Name == Normalized then
            return Name;
        end;
    end;

    return 'static';
end;

function Library:ApplyAccentLineGradient(Gradient, Style, Phase)
    local Main = Library.MainColor;
    local Accent = Library.AccentColor;
    local T = Phase % 1;

    Gradient.Rotation = 0;

    if Style == 'static' then
        Gradient.Offset = Vector2.new(0, 0);
        Gradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Accent);
            ColorSequenceKeypoint.new(1, Accent);
        });
    elseif Style == 'scroll' then
        Gradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Main);
            ColorSequenceKeypoint.new(0.4, Accent);
            ColorSequenceKeypoint.new(0.6, Accent);
            ColorSequenceKeypoint.new(1, Main);
        });
        Gradient.Offset = Vector2.new(T * 2 - 1, 0);
    elseif Style == 'scroll reverse' then
        Gradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Main);
            ColorSequenceKeypoint.new(0.4, Accent);
            ColorSequenceKeypoint.new(0.6, Accent);
            ColorSequenceKeypoint.new(1, Main);
        });
        Gradient.Offset = Vector2.new(1 - T * 2, 0);
    elseif Style == 'ripple' then
        local Spread = 0.03 + ((math.sin(T * math.pi * 2) + 1) * 0.5) * 0.47;
        local Center = 0.5;

        Gradient.Offset = Vector2.new(0, 0);
        Gradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Main);
            ColorSequenceKeypoint.new(math.clamp(Center - Spread, 0, 1), Main);
            ColorSequenceKeypoint.new(Center, Accent);
            ColorSequenceKeypoint.new(math.clamp(Center + Spread, 0, 1), Main);
            ColorSequenceKeypoint.new(1, Main);
        });
    elseif Style == 'shimmer' then
        Gradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Main);
            ColorSequenceKeypoint.new(0.48, Main);
            ColorSequenceKeypoint.new(0.5, Accent);
            ColorSequenceKeypoint.new(0.52, Main);
            ColorSequenceKeypoint.new(1, Main);
        });
        Gradient.Offset = Vector2.new(T * 2 - 1, 0);
    else
        Gradient.Offset = Vector2.new(0, 0);
        Gradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Accent);
            ColorSequenceKeypoint.new(1, Accent);
        });
    end;
end;

function Library:UpdateAccentLines(Delta)
    if #Library.AccentLines == 0 then
        return;
    end;

    local Speed = Library.AccentLineSpeed or 0.35;
    local Style = Library:NormalizeAccentLineStyle(Library.AccentLineStyle);

    if Style ~= 'static' then
        Library.AccentLinePhase = (Library.AccentLinePhase or 0) + Delta * Speed;
    end;

    local Phase = Library.AccentLinePhase or 0;

    for _, Entry in next, Library.AccentLines do
        Library:ApplyAccentLineGradient(Entry.Gradient, Style, Phase);
    end;
end;

function Library:SetAccentLineStyle(Style)
    Library.AccentLineStyle = Library:NormalizeAccentLineStyle(Style);

    if Library.AccentLineStyle == 'static' then
        for _, Entry in next, Library.AccentLines do
            Library:ApplyAccentLineGradient(Entry.Gradient, 'static', 0);
        end;
    end;
end;

function Library:SetAccentLineSpeed(Speed)
    Library.AccentLineSpeed = Speed;
end;

