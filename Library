            end;

            return tostring(Key);
        end;

        local function FormatKeyBracket(Key)
            if Key == nil or Key == '' or Key == 'None' then
                return '{-}';
            end;

            return '[' .. tostring(Key) .. ']';
        end;

        if KeyPicker.SyncToggleState then
