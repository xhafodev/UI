        Library:SetAccentLineSpeed(Options.AccentLineSpeed.Value / 100);
    end);
end;

function Library:NormalizeNotificationAnimationStyle(Style)
    if type(Style) ~= 'string' then
        return 'fade';
    end;

    local Normalized = Style:lower();

    for _, Name in next, Library.NotificationAnimationStyles do
        if Name == Normalized then
            return Name;
        end;
    end;

    return 'fade';
end;

function Library:NotificationStyleUses(Style, Token)
    if Style == 'none' then
        return false;
    end;

    if Style == Token then
        return true;
    end;

    return string.find(Style, Token, 1, true) ~= nil;
end;

function Library:SetNotificationAnimationStyle(Style)
    Library.NotificationAnimationStyle = Library:NormalizeNotificationAnimationStyle(Style);
end;

function Library:BuildNotificationSection(Groupbox)
    Groupbox:AddDropdown('NotificationAnimation', {
        Text = 'Notification animation';
        Values = Library.NotificationAnimationStyles;
        Default = Library:NormalizeNotificationAnimationStyle(Library.NotificationAnimationStyle);
        Multi = false;
    });

    Options.NotificationAnimation:OnChanged(function()
        Library:SetNotificationAnimationStyle(Options.NotificationAnimation.Value);
    end);
end;

function Library:AnimateNotificationIn(NotifyOuter, NotifyScale, FadeOverlay, TargetWidth, YSize)
    local Style = Library:NormalizeNotificationAnimationStyle(Library.NotificationAnimationStyle);
    local Duration = Library.NotificationAnimationDuration or 0.38;
    local TargetSize = UDim2.new(0, TargetWidth, 0, YSize);

    if Style == 'none' then
        NotifyOuter.Size = TargetSize;
        NotifyScale.Scale = 1;

        if FadeOverlay then
            FadeOverlay.Visible = false;
        end;

        return;
    end;

    local UsesFade = Library:NotificationStyleUses(Style, 'fade');
    local UsesScroll = Library:NotificationStyleUses(Style, 'scroll');
    local UsesBounce = Library:NotificationStyleUses(Style, 'bounce');

    if UsesScroll then
        NotifyOuter.Size = UDim2.new(0, 0, 0, YSize);
    else
        NotifyOuter.Size = TargetSize;
    end;

    if UsesBounce then
        NotifyScale.Scale = 0.72;
    else
        NotifyScale.Scale = 1;
    end;

    if UsesFade and FadeOverlay then
        FadeOverlay.BackgroundTransparency = 0;
        FadeOverlay.Visible = true;
        Library:Tween(FadeOverlay, { BackgroundTransparency = 1 }, Duration);
    elseif FadeOverlay then
        FadeOverlay.Visible = false;
    end;

    if UsesScroll then
        Library:Tween(NotifyOuter, { Size = TargetSize }, Duration);
    end;

    if UsesBounce then
        Library:Tween(
            NotifyScale,
            { Scale = 1 },
            Duration,
            Enum.EasingStyle.Back,
            Enum.EasingDirection.Out
        );
    end;
end;

function Library:AnimateNotificationOut(NotifyOuter, NotifyScale, FadeOverlay, TargetWidth, YSize, OnComplete)
    local Style = Library:NormalizeNotificationAnimationStyle(Library.NotificationAnimationStyle);
    local Duration = Library.NotificationAnimationDuration or 0.38;

    if Style == 'none' then
        if OnComplete then
            OnComplete();
        end;

        return;
    end;

    local UsesFade = Library:NotificationStyleUses(Style, 'fade');
    local UsesScroll = Library:NotificationStyleUses(Style, 'scroll');
    local UsesBounce = Library:NotificationStyleUses(Style, 'bounce');

    if UsesFade and FadeOverlay then
        FadeOverlay.BackgroundTransparency = 1;
        FadeOverlay.Visible = true;
        Library:Tween(
            FadeOverlay,
            { BackgroundTransparency = 0 },
            Duration,
            Enum.EasingStyle.Quad,
            Enum.EasingDirection.In
        );
    end;

    if UsesScroll then
        Library:Tween(
            NotifyOuter,
            { Size = UDim2.new(0, 0, 0, YSize) },
            Duration,
            Enum.EasingStyle.Quad,
            Enum.EasingDirection.In
        );
    end;

    if UsesBounce then
        Library:Tween(
            NotifyScale,
            { Scale = 0.72 },
            Duration,
            Enum.EasingStyle.Back,
            Enum.EasingDirection.In
        );
    end;

    task.delay(Duration, function()
        if OnComplete then
            OnComplete();
        end;
    end);
end;

function Library:RefreshAllKeybinds()
    for _, Option in next, Options do
        if Option.Type == 'KeyPicker' and Option.Update then
            Option:Update();
        end;
    end;
end;

function Library:SetKeybindShowOnlyActive(Bool)
    Library.KeybindShowOnlyActive = Bool;
    Library:RefreshAllKeybinds();
end;

function Library:ApplyKeybindTransparency()
    local Transparency = Library.KeybindTransparency or 0;

    if Library.KeybindOuter then
        Library.KeybindOuter.BackgroundTransparency = 1;
        Library.KeybindOuter.BorderSizePixel = 1;
    end;

    if Library.KeybindInner then
        Library.KeybindInner.BackgroundTransparency = Transparency;

        if Transparency >= 0.95 then
            Library.KeybindInner.BorderSizePixel = 0;
        else
            Library.KeybindInner.BorderSizePixel = 1;
        end;
    end;
end;

function Library:SetKeybindTransparency(Value)
    Library.KeybindTransparency = math.clamp(Value, 0, 1);
    Library:ApplyKeybindTransparency();
end;

local RainbowStep = 0
local Hue = 0

table.insert(Library.Signals, RenderStepped:Connect(function(Delta)
    RainbowStep = RainbowStep + Delta

    if RainbowStep >= (1 / 60) then
        RainbowStep = 0

        Hue = Hue + (1 / 400);

        if Hue > 1 then
            Hue = 0;
        end;

        Library.CurrentRainbowHue = Hue;
        Library.CurrentRainbowColor = Color3.fromHSV(Hue, 0.8, 1);
    end
end))

